# ===== LINE Messaging API =====
# 從 LINE Developers 後台 → 你的 Messaging API channel 取得
# Channel access token（Messaging API 分頁最下方，按 Issue 產生長字串）
LINE_CHANNEL_ACCESS_TOKEN=

# Channel secret（Basic settings 分頁）
LINE_CHANNEL_SECRET=

# ===== Anthropic (Claude) =====
# 從 https://console.anthropic.com → API Keys 取得
ANTHROPIC_API_KEY=

# 估算營養用的 Claude 模型（保持預設即可）
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== 伺服器設定 =====
# 本機伺服器的埠號，保持預設即可
PORT=3000
