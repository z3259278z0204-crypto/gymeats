# ===== LINE Messaging API =====
# 從 LINE Developers 後台 → 你的 Messaging API channel 取得
# Channel access token（Messaging API 分頁最下方，按 Issue 產生長字串）
LINE_CHANNEL_ACCESS_TOKEN=

# Channel secret（Basic settings 分頁）
LINE_CHANNEL_SECRET=

# ===== Anthropic (Claude) =====
# 從 https://console.anthropic.com → API Keys 取得
ANTHROPIC_API_KEY=

# 估算營養用的 Claude 模型（保持預設即可）
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== 伺服器設定 =====
# 本機伺服器的埠號，保持預設即可
PORT=3000

# ===== 雲端資料庫 Turso（重要：上線一定要設，資料才不會重啟後消失）=====
# 從 https://app.turso.tech 建立資料庫後取得。
# 本機測試可以「不填」→ 會自動改用本機檔案 data/gymeats.db。
# 但 Render 上線環境「一定要填」，否則資料每次重啟就清空。
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
